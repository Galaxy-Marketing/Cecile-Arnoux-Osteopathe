---
import { Image } from 'astro:assets';

interface Props {
  href: string;
  image: ImageMetadata;
  imageAlt: string;
  tag: string;
  title: string;
  desc: string;
  readTime: string;
}

const { href, image, imageAlt, tag, title, desc, readTime } = Astro.props;
---

<a href={href} class="blog-card reveal">
  <div class="blog-card-img-wrap">
    <Image src={image} alt={imageAlt} width={600} height={400} class="blog-card-img" loading="lazy" />
  </div>
  <div class="blog-card-body">
    <span class="blog-card-tag">{tag}</span>
    <h2 class="blog-card-title">{title}</h2>
    <p class="blog-card-desc">{desc}</p>
    <div class="blog-card-meta">{readTime}</div>
  </div>
</a>

<style>
  .blog-card {
    background: var(--cream); border: 1px solid var(--border);
    border-radius: 20px; overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
    text-decoration: none; color: inherit; display: block;
  }
  .blog-card:hover { transform: translateY(-6px); box-shadow: 0 20px 50px rgba(0,0,0,0.1); }
  .blog-card-img-wrap { width: 100%; aspect-ratio: 16/9; overflow: hidden; background: #e8ede9; }
  .blog-card-img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.5s;
  }
  .blog-card:hover .blog-card-img { transform: scale(1.04); }
  .blog-card-body { padding: 24px; }
  .blog-card-tag {
    font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--sage-dark);
    background: rgba(122,158,126,0.12); padding: 4px 12px;
    border-radius: 20px; display: inline-block; margin-bottom: 12px;
  }
  .blog-card-title {
    font-family: 'Playfair Display', serif; font-size: 19px;
    color: var(--text-dark); line-height: 1.3; margin-bottom: 10px;
  }
  .blog-card-desc {
    font-size: 13px; color: var(--text-mid); line-height: 1.7; margin-bottom: 16px;
  }
  .blog-card-meta {
    font-size: 12px; color: var(--text-light);
    display: flex; align-items: center; gap: 8px;
  }
  .blog-card-meta::before {
    content: ''; width: 20px; height: 1px;
    background: var(--sage-light); display: block;
  }
</style>
