---
import { Image } from 'astro:assets';

interface Props {
  image: ImageMetadata;
  imageAlt: string;
  tag: string;
  tagColor?: string;
  title: string;
  desc: string;
}

const { image, imageAlt, tag, tagColor = '#7A9E7E', title, desc } = Astro.props;
---

<div class="soin-card reveal">
  <div class="soin-img-wrap">
    <Image src={image} alt={imageAlt} width={600} height={400} class="soin-img" loading="lazy" />
  </div>
  <div class="soin-body">
    <h3>{title}</h3>
    <span class="soin-tag" style={`color: ${tagColor}; border-color: ${tagColor};`}>{tag}</span>
    <p>{desc}</p>
  </div>
</div>

<style>
  .soin-card {
    background: var(--warm-white); border: 1px solid var(--border);
    border-radius: 20px; overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .soin-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.08);
  }
  .soin-img-wrap { width: 100%; aspect-ratio: 3/2; overflow: hidden; }
  .soin-img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.5s;
  }
  .soin-card:hover .soin-img { transform: scale(1.04); }
  .soin-body { padding: 24px; }
  h3 {
    font-family: 'Playfair Display', serif;
    font-size: 18px; color: var(--text-dark); margin-bottom: 8px;
    line-height: 1.3;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--sage-light);
    display: inline-block;
  }
  .soin-tag {
    font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; border: 1px solid;
    padding: 3px 10px; border-radius: 20px;
    display: inline-block; margin: 10px 0;
  }
  p {
    font-size: 13px; color: var(--text-mid); line-height: 1.7; margin: 0;
  }
</style>
