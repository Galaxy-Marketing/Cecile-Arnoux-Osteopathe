---
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav';

import img1 from '../../../assets/images/img1.png';
import dosImg from '../../../assets/images/dos.jpg';
import nourrImg from '../../../assets/images/nourrisson.jpg';
import grossesseImg from '../../../assets/images/grossesse.jpg';
import sportifImg from '../../../assets/images/sportif.jpg';

const articles = [
  {
    href: '/en/blog/osteopath-vendome/',
    image: img1,
    imageAlt: 'Osteopath Vendôme',
    tag: 'Vendôme',
    title: 'Why see an osteopath in Vendôme?',
    desc: 'Everything you need to know before your first osteopathy consultation in Vendôme.',
  },
  {
    href: '/en/blog/back-pain/',
    image: dosImg,
    imageAlt: 'Back pain osteopathy',
    tag: 'Back & Spine',
    title: 'Back pain: when and why see an osteopath?',
    desc: 'Lumbar pain, sciatica, cervical pain: what osteopathy can do for your back.',
  },
  {
    href: '/en/blog/infant/',
    image: nourrImg,
    imageAlt: 'Infant osteopathy',
    tag: 'Infants',
    title: 'Infant osteopathy: colic, torticollis, sleep',
    desc: 'What paediatric osteopathy can do for your baby and when to book an appointment.',
  },
  {
    href: '/en/blog/pregnancy/',
    image: grossesseImg,
    imageAlt: 'Pregnancy osteopathy',
    tag: 'Pregnancy',
    title: 'Osteopathy and pregnancy: safe pain relief',
    desc: 'Pelvic pain, lumbar pain, sleep disorders: how osteopathy can support you during pregnancy.',
  },
  {
    href: '/en/blog/sports/',
    image: sportifImg,
    imageAlt: 'Sports osteopathy',
    tag: 'Sport',
    title: 'Osteopathy and sport: preventing injuries and tendinitis',
    desc: 'How osteopathy helps athletes prevent tendinitis and optimise recovery.',
  },
];
---

<BaseLayout
  title="Osteopathy Blog | Cécile Arnoux, Osteopath in Vendôme"
  description="Advice and information on osteopathy by Cécile Arnoux, osteopath in Vendôme (41100). Back pain, infants, pregnancy, sport."
  canonical="https://www.cecile-arnoux.com/en/blog/"
  lang="en"
  hreflangFr="https://www.cecile-arnoux.com/blog/"
  hreflangEn="https://www.cecile-arnoux.com/en/blog/"
>
  <Nav lang="en" activePage="blog" client:load />

  <div class="page-hero">
    <div class="label">Advice & information</div>
    <h1>The osteopathy <em>blog</em></h1>
    <p>Clear, expert information on osteopathy by Cécile Arnoux, osteopath D.O. in Vendôme.</p>
  </div>

  <div class="blog-grid">
    {articles.map(a => (
      <a href={a.href} class="blog-card">
        <div class="blog-card-img-wrap">
          <Image src={a.image} alt={a.imageAlt} width={600} height={400} class="blog-card-img" loading="lazy" />
        </div>
        <div class="blog-card-body">
          <span class="blog-card-tag">{a.tag}</span>
          <h2 class="blog-card-title">{a.title}</h2>
          <p class="blog-card-desc">{a.desc}</p>
        </div>
      </a>
    ))}
  </div>

  <footer class="footer-simple">
    <div class="footer-brand-name" style="font-size:18px;">Cécile Arnoux, Osteopath D.O. in Vendôme</div>
    <a href="/en/" class="footer-back">Back to site</a>
  </footer>
</BaseLayout>

<style>
  .page-hero {
    background: var(--sage-dark); padding: 140px 60px 80px; text-align: center;
  }
  .label { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--sage-light); font-weight: 600; margin-bottom: 14px; }
  h1 { font-family: 'Playfair Display', serif; font-size: clamp(36px, 5vw, 60px); color: white; line-height: 1.15; }
  h1 em { font-style: italic; color: var(--sage-light); }
  .page-hero p { color: rgba(255,255,255,0.7); font-size: 17px; margin-top: 16px; max-width: 500px; margin-left: auto; margin-right: auto; line-height: 1.7; }
  .blog-grid { max-width: 1100px; margin: 0 auto; padding: 80px 60px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .blog-card { background: var(--cream); border: 1px solid var(--border); border-radius: 20px; overflow: hidden; transition: transform 0.3s, box-shadow 0.3s; text-decoration: none; color: inherit; display: block; }
  .blog-card:hover { transform: translateY(-6px); box-shadow: 0 20px 50px rgba(0,0,0,0.1); }
  .blog-card-img-wrap { width: 100%; aspect-ratio: 16/9; overflow: hidden; background: #e8ede9; }
  .blog-card-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s; }
  .blog-card:hover .blog-card-img { transform: scale(1.04); }
  .blog-card-body { padding: 24px; }
  .blog-card-tag { font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--sage-dark); background: rgba(122,158,126,0.12); padding: 4px 12px; border-radius: 20px; display: inline-block; margin-bottom: 12px; }
  .blog-card-title { font-family: 'Playfair Display', serif; font-size: 19px; color: var(--text-dark); line-height: 1.3; margin-bottom: 10px; }
  .blog-card-desc { font-size: 13px; color: var(--text-mid); line-height: 1.7; margin-bottom: 16px; }
  @media (max-width: 900px) {
    .page-hero { padding: 120px 24px 60px; }
    .blog-grid { grid-template-columns: 1fr 1fr; padding: 50px 24px; gap: 20px; }
  }
  @media (max-width: 600px) {
    .blog-grid { grid-template-columns: 1fr; padding: 40px 20px; }
    h1 { font-size: 30px; }
  }
  @media (hover: none) {
    .blog-card:hover { transform: none; box-shadow: none; }
    .blog-card:hover .blog-card-img { transform: none; }
  }
</style>
